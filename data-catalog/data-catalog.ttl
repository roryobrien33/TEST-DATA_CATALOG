    skos:prefLabel "Simulation Software - OpenDSS" .

ex:data-processing a skos:Concept ;
    skos:definition "Procedures for data collection and processing" ;
    skos:prefLabel "data processing" .

ex:prompt-response-log a skos:Concept ;
    skos:definition "Logs of AI prompts and responses" ;
    skos:prefLabel "prompt response log" .

ex:regulatory-compliance a skos:Concept ;
    skos:definition "Documents related to regulatory compliance" ;
    skos:prefLabel "regulatory compliance" .

ex:test-data a skos:Concept ;
    skos:definition "Dataset used for testing AI models" ;
    skos:prefLabel "test data" .

ex:congestion-management a skos:Concept ;
    skos:definition "Transmission congestion management" ;
    skos:prefLabel "congestion management" .

ex:der-integration a skos:Concept ;
    skos:definition "Distributed Energy Resources integration" ;
    skos:prefLabel "DER integration" .

ex:energy-community a skos:Concept ;
    skos:definition "Local energy communities" ;
    skos:prefLabel "energy community" .

ex:sector-coupling a skos:Concept ;
