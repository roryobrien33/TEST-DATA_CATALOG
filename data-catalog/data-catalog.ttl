    dcterms:title "UC4 - Energy efficiency, management and sharing for local energy communities" .

ex:ai-system a skos:Concept ;
    skos:definition "Artificial Intelligence system or model" ;
    skos:prefLabel "AI system" .

ex:validation-data a skos:Concept ;
    skos:definition "Dataset used for validating AI models" ;
    skos:prefLabel "validation data" .

ex:training-data a skos:Concept ;
    skos:definition "Dataset used for training AI models" ;
    skos:prefLabel "training data" .

ex:energy a skos:Concept ;
    skos:altLabel "power" ;
    skos:definition "Energy domain related data" ;
    skos:prefLabel "energy" .

plcy:open-information a odrl:Policy ;
    dcterms:description """Data classified as "Open Information" is intended to be freely available 
and accessible to anyone without restrictions. This type of data generally 
does not contain sensitive information and can be shared both within and 
outside the organization.
Complies with FAIR principles: Findable, Accessible, Interoperable, Reusable.
""" ;
    dcterms:title "Open Information Policy" ;
    odrl:obligation plcy:open-license,
        plcy:open-make-accessible,
        plcy:open-register,
        plcy:open-rights ;
    odrl:permission plcy:open-info-access .

