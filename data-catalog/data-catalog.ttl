ex:referenceGrid-apulia a skos:Concept ;
    skos:definition "The location of the reference grid the historical data used in the Over-voltage simulation." ;
    skos:prefLabel "Reference Grid Location - Apulia, Italy" .

ex:referenceGrid-liguria a skos:Concept ;
    skos:definition "The location of the reference grid the historical data used in the Under-voltage simulation." ;
    skos:prefLabel "Reference Grid Location - Liguria, Italy" .

ex:sfasdggfvrln a dqv:QualityMeasurement ;
    dqv:computedOn ex:herrcgre ;
    dqv:isMeasurementOf ex:fkrhkqewjewrc ;
    dqv:value "0.9"^^xsd:float ;
    prov:generatedAtTime "2025-04-22"^^xsd:date .

ex:simulationScenario-overVoltage a skos:Concept ;
    skos:definition "The scenario the data will be used to simulate." ;
    skos:prefLabel "Simulation Scenario - Over-voltage" .

ex:simulationScenario-underVoltage a skos:Concept ;
    skos:definition "The scenario the data will be used to simulate." ;
    skos:prefLabel "Simulation Scenario - Under-voltage" .

