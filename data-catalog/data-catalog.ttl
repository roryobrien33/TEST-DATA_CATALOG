    skos:definition "The company/person who owns the data." ;
    skos:prefLabel "Data Ownership - EPRI" .

ex:dataSource-enel a skos:Concept ;
    skos:definition "Where the data was sourced from." ;
    skos:prefLabel "Data Source - ENEL" .

