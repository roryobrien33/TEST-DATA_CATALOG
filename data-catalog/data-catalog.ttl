ai-efct:The_AI-EFFECT_Data_Catalog a dcat:Catalog ;
    dcterms:description """This is the data catalog for the AI-EFFECT project. 


In an era dominated by digital transformation, the integration of Artificial Intelligence (AI) in critical infrastructure, particularly in the energy sector, promises enhanced efficiency, resilience, and sustainability.

The Digitalisation of the Energy System – EU Action Plan2 underscores the pivotal role of data and AI in shaping a more efficient, resilient, and sustainable energy landscape. However, challenges such as high-quality data availability, interoperability, and AI system security must be addressed to prevent potential threats and maintain integrity of critical infrastructure.

Additionally, regulatory challenges arise, in particular with the first European regulation on Artificial Intelligence (EU AI Act3) focusing on privacy, ethical concerns, and liability.

In this context, there is a critical need for an infrastructure for testing AI applications for the energy sector in an independent, protected environment, replicating conditions similar to real life. There is also a need for to validate the AI models in operational environments, to bridge the gap between laboratory and real-life adoption and between industry and research communities and European energy sector utilities.

learn more at https://ai-effect.eu
""" ;
    dcterms:license [ a dcterms:LicenseDocument ;
            dcterms:title "https://creativecommons.org/licenses/by-sa/4.0/" ] ;
    dcterms:publisher [ a foaf:Agent ;
            foaf:name "EPRI Europe" ] ;
    dcterms:title "The AI-EFFECT Data Catalog" ;
    adms:status "draft" .

plcy:ai-creating a odrl:Policy ;
    dcterms:description """Applies when the research focuses on creating an AI system as defined by the 
EU AI Act. The trained AI model needs to be published with corresponding metadata.
In case of conflicts with other classifications, the most stringent applies.
""" ;
    dcterms:title "Creating AI Policy" ;
    odrl:obligation plcy:ai-creating-documentation,
        plcy:ai-creating-prompt-logs,
        plcy:ai-creating-training-data,
        plcy:ai-creating-validation-data .

plcy:ai-creating-documentation a odrl:Duty ;
    dcterms:description """Must publish architectural documentation addressing:
- Written strategy for regulatory compliance and conformity assessment
- Procedures used in the development of the AI system and procedures 
  for quality control and quality assurance
- Examination, test and validation procedures to be carried out before, 
  during and after the deployment of the system
- Documentation of the systems and procedures used for data collection, 
  data analysis and labelling of training data
- A risk management system that addresses foreseeable risks including 
  safety risks and fundamental rights risks
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:ai-creating-prompt-logs a odrl:Duty ;
    dcterms:description """Must publish prompt-response logs that register the models inputs and outputs.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:ai-creating-training-data a odrl:Duty ;
    dcterms:description """Must publish the training dataset used to develop the AI system.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:ai-creating-validation-data a odrl:Duty ;
    dcterms:description """Must publish the validation dataset used for testing the validity of the model.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:ai-reporting a odrl:Policy ;
    dcterms:description """Applies when AI is used for reporting or dissemination activities (text, images, 
video or other media). Here, AI is not used for primary research activities, 
just for reporting on them.
""" ;
    dcterms:title "AI for Reporting Policy" ;
    odrl:obligation plcy:ai-reporting-attribution .

plcy:ai-reporting-attribution a odrl:Duty ;
    dcterms:description """If the artifact was entirely created using AI, attribution must state: 
"This [material/visual/text/...] was (in part) generated using AI. 
It was generated using [model name]+[model version] at [date]".
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:ai-using a odrl:Policy ;
    dcterms:description """Applies when AI is used for creating research artifacts or generating data. 
In this case, AI has been used during the research itself.
""" ;
    dcterms:title "Using AI Policy" ;
    odrl:obligation plcy:ai-using-provenance .

plcy:ai-using-provenance a odrl:Duty ;
    dcterms:description """Must provide provenance conforming to the prov-o standard, including:
- The Activity (the run of the AI system) that produced the dataset, 
  including when the Activity took place
- The AI system, including its version
- The input data(sets), including any prompts or configurations 
  like 'temperature' that the AI system used to produce the result.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:internal-access a odrl:Permission ;
    dcterms:description """Allows project members to access the data. Consumers outside the project 
do not have access unless agreed upon by the owner.
""" ;
    odrl:action "access" ;
    odrl:assignee "Data Consumer" .

plcy:internal-agreement a odrl:Duty ;
    dcterms:description """If the owner decides to share information with non-project members, 
appropriate arrangements must be made with the provider.
""" ;
    odrl:action "share" ;
    odrl:assignee "Data Provider" .

plcy:internal-information a odrl:Policy ;
    dcterms:description """Data classified as "Internal Information" is intended for use only within 
the project. While this data may not be considered highly sensitive, it is 
still restricted to employees or authorized personnel.
""" ;
    dcterms:title "Internal Information Policy" ;
    odrl:obligation plcy:internal-agreement,
        plcy:internal-store ;
    odrl:permission plcy:internal-access .

plcy:internal-store a odrl:Duty ;
    dcterms:description """Creators must save their information in the appropriate folders in the 
file sharing infrastructure available to the project.
""" ;
    odrl:action "store" ;
    odrl:assignee "Data Provider" .

plcy:open-info-access a odrl:Permission ;
    dcterms:description """Allows any consumer to access the data without restriction.
""" ;
    odrl:action "access" ;
    odrl:assignee "Data Consumer" .

plcy:open-license a odrl:Duty ;
    dcterms:description """The owner or creator must provide an open source or Creative Commons 
license describing the conditions under which a consumer may use the information.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:open-make-accessible a odrl:Duty ;
    dcterms:description """Providers must make the information available through an appropriate protocol.
""" ;
    odrl:action "make_available" ;
    odrl:assignee "Data Provider" .

plcy:open-register a odrl:Duty ;
    dcterms:description """The creator or owner must register the information in an indexed catalog 
so consumers can find it.
""" ;
    odrl:action "register" ;
    odrl:assignee "Data Provider" .

plcy:open-rights a odrl:Duty ;
    dcterms:description """The owner must provide a rights statement describing any IP or copyright 
that the owner and/or anyone else holds over the information.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:personal-access a odrl:Permission ;
    dcterms:description """Access is granted only to consumers/users that comply with GDPR conditions.
""" ;
    odrl:action "access" ;
    odrl:assignee "Data Consumer" .

plcy:personal-information a odrl:Policy ;
    dcterms:description """Data classified as "Personal Information" falls under the GDPR. This includes 
any data that can be used to identify, contact, or locate a single person.
Access must be granted in compliance with GDPR and limited to those consumers 
that fall under the conditions laid out in GDPR Article 6.
""" ;
    dcterms:title "Personal Information Policy" ;
    odrl:obligation plcy:personal-minimize,
        plcy:personal-purpose,
        plcy:personal-subject-rights ;
    odrl:permission plcy:personal-access .

plcy:personal-minimize a odrl:Duty ;
    dcterms:description """Collection of personal data must be minimized. All personal data must be 
deleted before the termination of the project.
""" ;
    odrl:action "delete" ;
    odrl:assignee "Data Provider" .

plcy:personal-purpose a odrl:Duty ;
    dcterms:description """The owner and creator must clearly state the purpose limitation with which 
the information was collected. Personal Information may only be shared if 
the subject has given permission.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:personal-subject-rights a odrl:Duty ;
    dcterms:description """The provider must allow subjects of Personal Information to claim their 
GDPR rights: Right of access, Right to rectification, Right to erasure.
""" ;
    odrl:action "allow" ;
    odrl:assignee "Service Provider" .

plcy:restricted-access a odrl:Permission ;
    dcterms:description """Only consumers with whom the owner has a data sharing agreement have access.
""" ;
    odrl:action "access" ;
    odrl:assignee "Data Consumer" .

plcy:restricted-agreement a odrl:Duty ;
    dcterms:description """The owner must provide a data sharing agreement stating addressing rights, 
licensing, and use limitations. Any consumer wishing access must agree 
to this agreement.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Data Provider" .

plcy:restricted-environment a odrl:Duty ;
    dcterms:description """The provider must provide an access-controlled environment for restricted data.
""" ;
    odrl:action "provide" ;
    odrl:assignee "Service Provider" .

plcy:restricted-information a odrl:Policy ;
    dcterms:description """Data classified as "Restricted Information" contains information that requires 
a higher level of protection due to its sensitivity. Access to this data is 
limited to specific individuals or groups based on their role within the project.
Unlike internal information, restricted information is meant for sharing with 
those that have received explicit permission.
""" ;
    dcterms:title "Restricted Information Policy" ;
    odrl:obligation plcy:restricted-agreement,
        plcy:restricted-environment ;
    odrl:permission plcy:restricted-access .

ex:fkrhkqewjewrc a dqv:Metric ;
    skos:definition "an example of a data quality metric" ;
    skos:prefLabel "example metric" ;
    dqv:expectedDataType xsd:float ;
    dqv:inDimension "Completeness" .

ex:dataFormat-csv a skos:Concept ;
    skos:definition "The format of the dataset distribution." ;
    skos:prefLabel "Dataset Distribution Format - CSV" .

