    dcterms:title "UC3 - DER integration into Distribution Systems" .

ex:uc4-energy-efficiency-local-communities a dcat:DatasetSeries ;
    dcterms:description """This series contains all the datasets related to the creation of AI systems 
for the Energy efficiency, management and sharing for local energy communities 
usecase of the AI-EFFECT project.
""" ;
    dcterms:publisher [ a foaf:Agent ;
